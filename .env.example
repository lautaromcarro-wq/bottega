# ConvertKit (Kit) integration for the waitlist form
# Get these from: https://app.kit.com/account_settings/advanced_settings
#
# 1. API Key — Public key, safe to use client-side per ConvertKit docs
# 2. Form ID — Create a form in Kit, then open its URL. The numeric ID
#    at the end of the URL is the Form ID.
#
# Local dev: copy this file to .env and fill in values.
# Production: set these as Environment Variables in Vercel dashboard
# (Project → Settings → Environment Variables). Both Production and
# Preview environments should have them.

VITE_CONVERTKIT_API_KEY=your_public_api_key_here
VITE_CONVERTKIT_FORM_ID=your_numeric_form_id_here
